# ─── TiDB ────────────────────────────────────────────────────────────────────
# Option A — full DSN (takes priority if set)
TIDB_DSN=

# Option B — individual components
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=

# CA certificate for TLS verification (recommended for TiDB Cloud)
# _FILE takes priority over the raw value.
TIDB_CA_CERT_FILE=/path/to/isrgrootx1.pem
# TIDB_CA_CERT=-----BEGIN CERTIFICATE-----...

# ─── Gmail API ───────────────────────────────────────────────────────────────
# Sender address (required in both modes)
GMAIL_FROM_EMAIL=you@gmail.com

# Mode A — Google JSON files (credentials.json + token.json from Cloud Console)
# _FILE takes priority over the raw JSON value.
GMAIL_CREDENTIALS_FILE=/path/to/credentials.json
GMAIL_TOKEN_FILE=/path/to/token.json

# Mode B — individual values (used when GMAIL_CREDENTIALS is not set)
# Each also accepts a _FILE companion, e.g. GMAIL_CLIENT_ID_FILE=...
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
