# ─── TiDB ────────────────────────────────────────────────────────────────────
# Option A — full DSN (takes priority if set)
TIDB_DSN=

# Option B — individual components
TIDB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=

# CA certificate for TLS verification (recommended for TiDB Cloud)
# Accepts a file path or raw PEM content.
TIDB_CA_CERT=/path/to/isrgrootx1.pem

# ─── Gmail API ───────────────────────────────────────────────────────────────
# Sender address (required in both modes)
GMAIL_FROM_EMAIL=you@gmail.com

# Mode A — Google JSON files (credentials.json + token.json from Cloud Console)
# Each accepts a file path or raw JSON content.
GMAIL_CREDENTIALS=/path/to/credentials.json
GMAIL_TOKEN=/path/to/token.json

# Mode B — individual values (used when GMAIL_CREDENTIALS is not set)
# Each accepts a file path or raw value.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
